# ============================================================
# Vision2Voice — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Model weights (too large for git — use Google Drive / DVC) ---
models/*.h5
models/*.pkl
models/*.pt
models/*.pth
models/*.onnx
# Keep the placeholder
!models/.gitkeep

# --- YOLOv8 auto-downloaded weights ---
*.pt

# --- Generated outputs ---
outputs/
!outputs/.gitkeep

# --- Streamlit ---
.streamlit/secrets.toml

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Environment & secrets ---
.env
.env.*
secrets.yaml
*.secret

# --- Testing ---
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# --- Type checking ---
.mypy_cache/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Logs ---
*.log
logs/

# --- Temp files ---
temp_*
tmp/
