n","        cropped_image.save(os.path.join(output_folder, filename))\n","\n","        # Display the cropped image\n","        plt.subplot(1, len(result.boxes) + 1, i + 2)\n","        plt.imshow(cropped_image)\n","        plt.title(f\"{class_id} ({conf})\")\n","        plt.axis('off')\n","\n","        print(f\"Cropped and saved {filename}\")\n","\n","    print(\"Cropping completed.\")\n","\n","    # Show the original and cropped images\n","    plt.tight_layout()\n","    plt.show()\n","\n","# Example usage:\n","input_image_path = \"/content/children_playing.jpg\"\n","#Put path of google drive\n","output_folder = \"cropped_images\"\n","detect_and_crop_objects(input_image_path, output_folder)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":521},"id":"yFrqoGT4i-vm","executionInfo":{"status":"ok","timestamp":1694927467620,"user_tz":-330,"elapsed":8309,"user":{"displayName":"GPU Project","userId":"15085089152588404930"}},"outputId":"f6b98192-4ef8-43ce-e90e-d94bc60a8f35"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["\n","0: 384x640 5 persons, 1 bench, 1 sports ball, 2772.5ms\n","Speed: 4.0ms preprocess, 2772.5ms inference, 1.6ms postprocess per image at shape (1, 3, 384, 640)\n"]},{"output_type":"stream","name":"stdout","text":["Cropped and saved person_0.94.jpg\n","Cropped and saved person_0.92.jpg\n","Cropped and saved sports ball_0.91.jpg\n","Cropped and saved person_0.9.jpg\n","Cropped and saved person_0.7.jpg\n","Cropped and saved person_0.41.jpg\n","Cropped and saved bench_0.35.jpg\n","Cropping completed.\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 8 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["obj1 = cv2.imread('/content/cropped_images/person_0.94.jpg')\n","cv2_imshow(obj1)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":341},"id":"wZf5u_L4ktT4","executionInfo":{"status":"ok","timestamp":1694928373990,"user_tz":-330,