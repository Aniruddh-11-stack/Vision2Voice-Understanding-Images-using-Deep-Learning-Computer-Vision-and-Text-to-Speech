[flake8]
max-line-length = 100
extend-ignore =
    # E203: whitespace before ':' — conflicts with black
    E203,
    # W503: line break before binary operator — PEP8 updated
    W503,
    # E501: line too long — handled by black
    E501
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    .eggs,
    *.egg-info,
    build,
    dist,
    notebooks/
per-file-ignores =
    # Allow unused imports in __init__ files (public API re-exports)
    __init__.py: F401
